public List<Answer> findAll() {
    return jdbcTemplate.query("""
        SELECT
            t.title,
            u.name AS user_name,
            a.main_text,
            a.created_at,
            COUNT(g.good_id) AS good_count
        FROM answer AS a
        INNER JOIN title AS t
            ON a.title_id = t.title_id
        INNER JOIN user_info AS u
            ON a.user_id = u.user_id
        LEFT JOIN good AS g
            ON a.answer_id = g.answer_id
        GROUP BY
            a.answer_id,
            t.title,
            u.name,
            a.main_text,
            a.created_at
        """, mapper);
}

